---
// src/components/Hero.astro
---

<section id="home" class="min-h-screen flex items-center pt-20 pb-16 px-6">
  <div class="max-w-6xl mx-auto w-full">
    <div class="max-w-3xl">

      <!-- Greeting badge -->
      <div class="animate-on-scroll mb-5">
        <span
          class="inline-flex items-center gap-2 font-mono text-sm text-accent-teal tracking-widest"
        >
          <span class="w-8 h-px bg-accent-teal/60 inline-block"></span>
          Halo, saya
        </span>
      </div>

      <!-- Main name -->
      <h1
        class="animate-on-scroll delay-100 text-5xl sm:text-6xl lg:text-7xl font-bold text-white leading-tight tracking-tight mb-4"
      >
        Arvian <span class="text-accent-teal">Randitya</span>
      </h1>

      <!-- Typewriter sub-headline -->
      <h2
        class="animate-on-scroll delay-200 text-2xl sm:text-3xl lg:text-4xl font-light text-accent-slate mb-6 leading-snug"
      >
        <span id="typewriter-text"></span>
        <span class="font-mono text-accent-teal animate-blink ml-0.5">_</span>
      </h2>

      <!-- Description -->
      <p
        class="animate-on-scroll delay-300 text-accent-slate text-base sm:text-lg leading-relaxed max-w-xl mb-10"
      >
        Web Developer & Mahasiswa Teknik Informatika. Berpengalaman membangun sistem web fungsional menggunakan Laravel di lingkungan universitas. Fokus pada solusi teknologi yang efisien dan user-friendly.
      </p>

      <!-- CTA Buttons -->
      <div class="animate-on-scroll delay-400 flex flex-wrap gap-4 items-center">
        <a
          href="#projects"
          class="group inline-flex items-center gap-2 px-6 py-3 bg-accent-teal text-navy-900 font-semibold text-sm rounded hover:bg-accent-teal/90 transition-all duration-200 hover:shadow-lg hover:shadow-accent-teal/20"
        >
          Lihat Portfolio
          <svg
            class="w-4 h-4 group-hover:translate-x-1 transition-transform"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
          </svg>
        </a>

        <a
          href="#contact"
          class="inline-flex items-center gap-2 px-6 py-3 border border-accent-slate/40 text-accent-slate text-sm rounded hover:border-accent-teal hover:text-accent-teal transition-all duration-200"
        >
          Hubungi Saya
        </a>
      </div>

      <!-- Stats quick info -->
      <div class="animate-on-scroll delay-500 flex flex-wrap gap-8 mt-14 pt-10 border-t border-white/5">
        {
          [
            { value: '2', label: 'Proyek Selesai' },
            { value: '3.82', label: 'IPK Kumulatif' },
          ].map((stat) => (
            <div>
              <div class="text-2xl font-bold text-white font-mono">
                {stat.value}
                <span class="text-accent-teal">+</span>
              </div>
              <div class="text-xs text-accent-slate mt-0.5 tracking-wide">{stat.label}</div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Decorative scroll indicator -->
  <div
    class="absolute bottom-8 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center gap-1.5 text-accent-slate/50"
  >
    <span class="text-xs font-mono tracking-widest">scroll</span>
    <div class="w-px h-12 bg-gradient-to-b from-accent-slate/40 to-transparent"></div>
  </div>
</section>

<script>
  // Typewriter effect
  const phrases = [
    'Informatics Engineering Student',
    'Web Developer',
    'Network Engineer',
    'AI/ML Enthusiast',
  ];

  let phraseIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  const el = document.getElementById('typewriter-text');

  function type() {
    const current = phrases[phraseIndex];
    if (!el) return;

    if (isDeleting) {
      el.textContent = current.substring(0, charIndex - 1);
      charIndex--;
    } else {
      el.textContent = current.substring(0, charIndex + 1);
      charIndex++;
    }

    let delay = isDeleting ? 50 : 90;

    if (!isDeleting && charIndex === current.length) {
      delay = 2000;
      isDeleting = true;
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      phraseIndex = (phraseIndex + 1) % phrases.length;
      delay = 400;
    }

    setTimeout(type, delay);
  }

  setTimeout(type, 800);
</script>
