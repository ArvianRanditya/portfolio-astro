---
// src/components/Education.astro
import { education } from '../data/portfolio';
---

<section id="education" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">

    <!-- Section Header -->
    <div class="animate-on-scroll mb-16">
      <p class="font-mono text-accent-teal text-sm mb-2 tracking-widest">02. education</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white section-title">
        Riwayat Pendidikan
      </h2>
    </div>

    <!-- Timeline -->
    <div class="relative max-w-3xl">
      {
        education.map((edu, index) => (
          <div class="animate-on-scroll relative flex gap-8 pb-12 last:pb-0">
            <!-- Timeline dot + line -->
            <div class="relative flex-shrink-0 mt-1">
              <div class="w-4 h-4 rounded-full bg-navy-900 border-2 border-accent-teal shadow-[0_0_12px_rgba(100,255,218,0.4)] z-10 relative" />
              {index < education.length - 1 && (
                <div class="timeline-line" />
              )}
            </div>

            <!-- Content card -->
            <div class="flex-1 bg-navy-800/40 border border-white/5 rounded-xl p-6 hover:border-accent-teal/30 transition-all duration-300 hover:bg-navy-800/60 card-hover">

              <!-- Header -->
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2 mb-3">
                <div>
                  <h3 class="text-white font-semibold text-lg leading-tight">
                    {edu.institution}
                  </h3>
                  <p class="text-accent-teal font-mono text-sm mt-0.5">
                    {edu.degree} – {edu.major}
                  </p>
                </div>
                <div class="flex-shrink-0">
                  <span class="inline-block bg-navy-950/60 border border-white/10 text-accent-slate font-mono text-xs px-3 py-1 rounded-full">
                    {edu.period}
                  </span>
                </div>
              </div>

              <!-- GPA -->
              {edu.gpa && (
                <div class="flex items-center gap-2 mb-4">
                  <div class="h-px flex-1 bg-white/5" />
                  <div class="flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                    </svg>
                    <span class="text-xs font-mono text-yellow-400/80">IPK {edu.gpa}</span>
                  </div>
                  <div class="h-px flex-1 bg-white/5" />
                </div>
              )}

              <!-- Achievements -->
              {edu.achievements && edu.achievements.length > 0 && (
                <ul class="space-y-1.5">
                  {edu.achievements.map((item) => (
                    <li class="flex items-start gap-2.5 text-accent-slate text-sm">
                      <svg
                        class="w-3.5 h-3.5 text-accent-teal flex-shrink-0 mt-0.5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M9 12l2 2 4-4"
                        />
                      </svg>
                      {item}
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
