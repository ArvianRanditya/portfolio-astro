---
// src/components/Projects.astro
import { projects } from '../data/portfolio';

// Badge color map per category
const categoryColors: Record<string, string> = {
  'Web':    'bg-blue-500/15 text-blue-400 border-blue-500/30',
  'Mobile': 'bg-purple-500/15 text-purple-400 border-purple-500/30',
  'AI/ML':  'bg-rose-500/15 text-rose-400 border-rose-500/30',
  'IoT':    'bg-emerald-500/15 text-emerald-400 border-emerald-500/30',
  'Game':   'bg-orange-500/15 text-orange-400 border-orange-500/30',
  'Other':  'bg-slate-500/15 text-slate-400 border-slate-500/30',
};
---

<section id="projects" class="py-24 px-6 bg-navy-950/30">
  <div class="max-w-6xl mx-auto">

    <!-- Section Header -->
    <div class="animate-on-scroll mb-5">
      <p class="font-mono text-accent-teal text-sm mb-2 tracking-widest">03. projects</p>
      <div class="flex items-end justify-between flex-wrap gap-4">
        <h2 class="text-3xl sm:text-4xl font-bold text-white section-title">
          Proyek Pilihan
        </h2>
        <a
          href="https://github.com/username"
          target="_blank"
          class="font-mono text-xs text-accent-teal hover:underline"
        >
          Lihat semua di GitHub →
        </a>
      </div>
    </div>

    <!-- Filter hint -->
    <p class="animate-on-scroll text-accent-slate/60 text-sm font-mono mb-12">
      // {projects.length} proyek
    </p>

    <!-- Projects grid -->
    <!--
      ====================================================
      📝 CARA MENAMBAH PROYEK BARU:
      Edit file: src/data/portfolio.ts
      Tambahkan object baru ke array `projects`.
      Grid ini akan otomatis menampilkan proyek baru.
      ====================================================
    -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {
        projects.map((project, index) => (
          <article
            class={`animate-on-scroll group relative bg-navy-800/40 border border-white/5 rounded-2xl overflow-hidden card-hover ${index === 0 ? '' : ''}`}
            style={`animation-delay: ${index * 100}ms`}
          >
            <!-- Project image -->
            <div class="relative overflow-hidden h-48 bg-navy-950">
              <img
                src={project.image}
                alt={`Screenshot proyek ${project.title}`}
                class="w-full h-full object-cover opacity-70 group-hover:opacity-90 group-hover:scale-105 transition-all duration-500"
                loading="lazy"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
              />
              <!-- Fallback placeholder jika gambar belum ada -->
              <div
                class="absolute inset-0 hidden items-center justify-center bg-gradient-to-br from-navy-950 via-navy-800 to-navy-950"
                style="display: none"
              >
                <div class="text-center">
                  <div class="text-4xl mb-2">
                    {project.category === 'IoT' ? '🔌' : project.category === 'AI/ML' ? '🤖' : project.category === 'Mobile' ? '📱' : '💻'}
                  </div>
                  <p class="text-accent-slate/50 font-mono text-xs">{project.category}</p>
                </div>
              </div>
              <!-- Overlay gradient -->
              <div class="absolute inset-0 bg-gradient-to-t from-navy-950/80 to-transparent" />

              <!-- Category badge overlay -->
              <div class="absolute top-3 right-3">
                <span class={`inline-block border text-xs font-mono px-2.5 py-1 rounded-full backdrop-blur-sm ${categoryColors[project.category]}`}>
                  {project.category}
                </span>
              </div>

              <!-- Featured badge -->
              {project.featured && (
                <div class="absolute top-3 left-3">
                  <span class="inline-flex items-center gap-1 bg-accent-teal/15 border border-accent-teal/30 text-accent-teal text-xs font-mono px-2.5 py-1 rounded-full backdrop-blur-sm">
                    ✦ Featured
                  </span>
                </div>
              )}
            </div>

            <!-- Project content -->
            <div class="p-6">
              <h3 class="text-white font-semibold text-lg mb-2 group-hover:text-accent-teal transition-colors leading-snug">
                {project.title}
              </h3>

              <p class="text-accent-slate text-sm leading-relaxed mb-4 line-clamp-2">
                {project.description}
              </p>

              <!-- Tech tags -->
              <div class="flex flex-wrap gap-1.5 mb-5">
                {project.tags.map((tag) => (
                  <span class="font-mono text-xs text-accent-slate/70 bg-white/5 px-2 py-0.5 rounded">
                    {tag}
                  </span>
                ))}
              </div>

              <!-- Links -->
              <div class="flex items-center gap-4 pt-4 border-t border-white/5">
                {project.repoUrl && (
                  <a
                    href={project.repoUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 text-accent-slate hover:text-white text-sm transition-colors"
                    aria-label="GitHub Repository"
                  >
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                    </svg>
                    Source
                  </a>
                )}
                {project.liveUrl && (
                  <a
                    href={project.liveUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 text-accent-teal hover:text-accent-teal/80 text-sm transition-colors"
                    aria-label="Live Demo"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                    Live Demo
                  </a>
                )}
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
