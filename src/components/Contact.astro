---
// src/components/Contact.astro
import { contact } from '../data/portfolio';
---

<section id="contact" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">

    <!-- Section Header -->
    <div class="animate-on-scroll mb-16">
      <p class="font-mono text-accent-teal text-sm mb-2 tracking-widest">04. contact</p>
      <h2 class="text-3xl sm:text-4xl font-bold text-white section-title">
        Mari Terhubung
      </h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">

      <!-- Left: CTA text -->
      <div class="animate-on-scroll">
        <p class="text-accent-slate text-base sm:text-lg leading-relaxed mb-8">
          Saya terbuka untuk peluang magang, kolaborasi proyek, atau sekadar
          ngobrol soal teknologi. Jangan ragu untuk menghubungi saya — inbox
          saya selalu terbuka!
        </p>

        <a
          href={`mailto:${contact.email}`}
          class="group inline-flex items-center gap-3 px-7 py-4 border border-accent-teal text-accent-teal font-mono text-sm rounded hover:bg-accent-teal/10 transition-all duration-200 hover:gap-4"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          {contact.email}
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>

      <!-- Right: Social links -->
      <div class="animate-on-scroll delay-200">
        <p class="text-xs font-mono text-accent-slate/60 tracking-widest mb-5 uppercase">
          // Temukan saya di
        </p>
        <div class="space-y-4">

          <!-- GitHub -->
          <a
            href={contact.github}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 group p-4 rounded-xl border border-white/5 hover:border-accent-teal/30 hover:bg-navy-800/40 transition-all duration-200"
          >
            <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-white/5 group-hover:bg-accent-teal/10 transition-colors">
              <svg class="w-5 h-5 text-accent-slate group-hover:text-accent-teal transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
            </div>
            <div>
              <p class="text-white text-sm font-medium">GitHub</p>
              <p class="text-accent-slate text-xs font-mono">@ArvianRanditya</p>
            </div>
            <svg class="w-4 h-4 text-accent-slate ml-auto opacity-0 group-hover:opacity-100 group-hover:text-accent-teal transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>

          <!-- LinkedIn -->
          <a
            href={contact.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 group p-4 rounded-xl border border-white/5 hover:border-accent-teal/30 hover:bg-navy-800/40 transition-all duration-200"
          >
            <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-white/5 group-hover:bg-accent-teal/10 transition-colors">
              <svg class="w-5 h-5 text-accent-slate group-hover:text-accent-teal transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </div>
            <div>
              <p class="text-white text-sm font-medium">LinkedIn</p>
              <p class="text-accent-slate text-xs font-mono">linkedin.com/in/arvianranditya</p>
            </div>
            <svg class="w-4 h-4 text-accent-slate ml-auto opacity-0 group-hover:opacity-100 group-hover:text-accent-teal transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>

          <!-- Instagram -->
          <a
            href={contact.instagram}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 group p-4 rounded-xl border border-white/5 hover:border-accent-teal/30 hover:bg-navy-800/40 transition-all duration-200"
          >
            <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-white/5 group-hover:bg-accent-teal/10 transition-colors">
              <svg class="w-5 h-5 text-accent-slate group-hover:text-accent-teal transition-colors" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
              </svg>
            </div>
            <div>
              <p class="text-white text-sm font-medium">Instagram</p>
              <p class="text-accent-slate text-xs font-mono">@arvian.randitya</p>
            </div>
            <svg class="w-4 h-4 text-accent-slate ml-auto opacity-0 group-hover:opacity-100 group-hover:text-accent-teal transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Footer bottom -->
    <div class="mt-20 pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="font-mono text-xs text-accent-slate/50">
        Designed & Built by <span class="text-accent-teal">Arvian Randitya</span>
      </p>
      <p class="font-mono text-xs text-accent-slate/30">
        Built with Astro + Tailwind CSS · {new Date().getFullYear()}
      </p>
    </div>
  </div>
</section>
